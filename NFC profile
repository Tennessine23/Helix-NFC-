import { useState, useRef } from "react";
import {
  Pencil, Check, Camera, Plus, Trash2, Mail, Phone,
  Globe, MapPin, Instagram, Linkedin, Twitter,
  Music2, Github, Youtube, MessageCircle,
  Link, ExternalLink
} from "lucide-react";

const LOGO_MARK = "data:image/png;base64,";

const PLATFORM_ICONS = {
  instagram: Instagram,
  linkedin: Linkedin,
  x: Twitter,
  tiktok: Music2,
  github: Github,
  youtube: Youtube,
  whatsapp: MessageCircle,
  website: Globe,
  other: Link,
};

const PLATFORM_LABELS = {
  instagram: "Instagram",
  linkedin: "LinkedIn",
  x: "X (Twitter)",
  tiktok: "TikTok",
  github: "GitHub",
  youtube: "YouTube",
  whatsapp: "WhatsApp",
  website: "Website",
  other: "Other",
};

const ACCENTS = {
  clay: { name: "Clay", base: "#C2552E", soft: "#F4E4DC", text: "#7A331A" },
  ink: { name: "Ink", base: "#33415C", soft: "#E4E8EE", text: "#1F2937" },
  fern: { name: "Fern", base: "#3C6E47", soft: "#E2EDE3", text: "#234A2D" },
  plum: { name: "Plum", base: "#6B4577", soft: "#ECE3EF", text: "#432B4D" },
  navy: { name: "Navy", base: "#33457A", soft: "#E2E6F0", text: "#222F54" },
};

const DEFAULT_PROFILE = {
  name: "Matthew Karanja",
  title: "CEO. Helix Tech.",
  company: "Helix Tech",
  bio: "I design calm, useful interfaces. Based in Nairobi, working with teams everywhere.",
  email: "lmknganga@gmail.com",
  phone: "+254 798184245",
  location: "Nairobi, Kenya",
  photo: "",
  accent: "navy",
  links: [
    { id: "l1", platform: "linkedin", value: "linkedin.com/in/Matthew Karanja" },
    { id: "l2", platform: "instagram", value: "@chihiroyamanakasburner_" },
    { id: "l3", platform: "website", value: "studiolumen.co" },
  ],
};

function initials(name) {
  return name
    .split(" ")
    .map((p) => p[0])
    .filter(Boolean)
    .slice(0, 2)
    .join("")
    .toUpperCase();
}

function normalizeLink(platform, value) {
  const v = value.trim();
  if (!v) return "#";
  if (v.startsWith("http://") || v.startsWith("https://")) return v;
  if (platform === "whatsapp") return `https://wa.me/${v.replace(/[^\d]/g, "")}`;
  if (platform === "instagram") return `https://www.instagram.com/chihiroyamanakasburner_?igsh=amlycGtnbmR4ODVo;
  if (platform === "x") return `https://x.com/${v.replace("@", "")}`;
  if (platform === "tiktok") return `https://tiktok.com/@${v.replace("@", "")}`;
  return `https://${v}`;
}

export default function NFCProfileCard() {
  const [profile, setProfile] = useState(DEFAULT_PROFILE);
  const [editing, setEditing] = useState(false);
  const [saved, setSaved] = useState(false);
  const fileRef = useRef(null);
  const accent = ACCENTS[profile.accent];

  const update = (field, value) =>
    setProfile((p) => ({ ...p, [field]: value }));

  const updateLink = (id, field, value) =>
    setProfile((p) => ({
      ...p,
      links: p.links.map((l) => (l.id === id ? { ...l, [field]: value } : l)),
    }));

  const addLink = () =>
    setProfile((p) => ({
      ...p,
      links: [...p.links, { id: `l${Date.now()}`, platform: "website", value: "" }],
    }));

  const removeLink = (id) =>
    setProfile((p) => ({ ...p, links: p.links.filter((l) => l.id !== id) }));

  const handlePhoto = (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => update("photo", reader.result);
    reader.readAsDataURL(file);
  };

  const toggleEdit = () => {
    if (editing) {
      setSaved(true);
      setTimeout(() => setSaved(false), 1800);
    }
    setEditing((e) => !e);
  };

  return (
    <div
      style={{
        background: accent.base,
        borderRadius: "var(--border-radius-lg)",
        padding: "2rem 1rem",
        position: "relative",
        overflow: "hidden",
      }}
    >
      <div
        aria-hidden="true"
        style={{
          position: "absolute",
          inset: 0,
          backgroundImage: `url(${LOGO_MARK})`,
          backgroundRepeat: "no-repeat",
          backgroundPosition: "center center",
          backgroundSize: "480px 480px",
          opacity: 0.06,
          pointerEvents: "none",
        }}
      />
      <div style={{ maxWidth: 380, margin: "0 auto", fontFamily: "var(--font-sans)", position: "relative" }}>
      <h2 className="sr-only" style={{ position: "absolute", left: "-9999px" }}>
        Customizable NFC digital profile card showing a profile photo, name, title,
        bio, contact details, and social links, with an edit mode for personalizing
        every field and an accent color picker.
      </h2>

      {/* Accent picker + edit toggle */}
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 12 }}>
        <div style={{ display: "flex", gap: 6 }}>
          {Object.entries(ACCENTS).map(([key, val]) => (
            <button
              key={key}
              aria-label={`Use ${val.name} accent`}
              onClick={() => update("accent", key)}
              style={{
                width: 22,
                height: 22,
                borderRadius: "50%",
                background: val.base,
                border: profile.accent === key ? "2px solid #fff" : "2px solid rgba(255,255,255,0.4)",
                padding: 0,
                cursor: "pointer",
              }}
            />
          ))}
        </div>
        <button
          onClick={toggleEdit}
          style={{ display: "flex", alignItems: "center", gap: 6, fontSize: 13, color: "#fff", borderColor: "rgba(255,255,255,0.4)", background: "rgba(255,255,255,0.08)" }}
        >
          {editing ? <Check size={16} aria-hidden="true" /> : <Pencil size={16} aria-hidden="true" />}
          {editing ? "Done" : "Edit profile"}
        </button>
      </div>

      {/* Card */}
      <div
        style={{
          background: "var(--color-background-primary)",
          border: "0.5px solid var(--color-border-tertiary)",
          borderRadius: "var(--border-radius-lg)",
          overflow: "hidden",
        }}
      >
        {/* Header band */}
        <div style={{ background: accent.soft, height: 80, position: "relative" }} />

        {/* Photo */}
        <div style={{ display: "flex", justifyContent: "center", marginTop: -40 }}>
          <div style={{ position: "relative" }}>
            <div
              style={{
                width: 80,
                height: 80,
                borderRadius: "50%",
                border: "3px solid var(--color-background-primary)",
                background: profile.photo ? `url(${profile.photo})` : "#E8A03C",
                backgroundSize: "cover",
                backgroundPosition: "center",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                color: "#3A2A0A",
                fontSize: 22,
                fontWeight: 500,
              }}
            >
              {!profile.photo && initials(profile.name)}
            </div>
            {editing && (
              <button
                onClick={() => fileRef.current?.click()}
                aria-label="Change profile photo"
                style={{
                  position: "absolute",
                  bottom: -2,
                  right: -2,
                  width: 28,
                  height: 28,
                  borderRadius: "50%",
                  background: "var(--color-background-primary)",
                  border: "0.5px solid var(--color-border-secondary)",
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "center",
                  padding: 0,
                  cursor: "pointer",
                }}
              >
                <Camera size={14} aria-hidden="true" />
              </button>
            )}
            <input
              ref={fileRef}
              type="file"
              accept="image/*"
              onChange={handlePhoto}
              style={{ display: "none" }}
            />
          </div>
        </div>

        {/* Identity */}
        <div style={{ textAlign: "center", padding: "12px 24px 0" }}>
          {editing ? (
            <>
              <input
                value={profile.name}
                onChange={(e) => update("name", e.target.value)}
                placeholder="Full name"
                style={{ textAlign: "center", fontSize: 18, fontWeight: 500, width: "100%" }}
              />
              <div style={{ display: "flex", gap: 6, marginTop: 6 }}>
                <input
                  value={profile.title}
                  onChange={(e) => update("title", e.target.value)}
                  placeholder="Title"
                  style={{ textAlign: "center", fontSize: 13, flex: 1 }}
                />
                <input
                  value={profile.company}
                  onChange={(e) => update("company", e.target.value)}
                  placeholder="Company"
                  style={{ textAlign: "center", fontSize: 13, flex: 1 }}
                />
              </div>
            </>
          ) : (
            <>
              <p style={{ fontSize: 18, fontWeight: 500, margin: 0 }}>{profile.name}</p>
              <p style={{ fontSize: 13, color: "var(--color-text-secondary)", margin: "2px 0 0" }}>
                {profile.title}
                {profile.company ? ` · ${profile.company}` : ""}
              </p>
            </>
          )}
        </div>

        {/* Bio */}
        <div style={{ padding: "12px 24px 0" }}>
          {editing ? (
            <textarea
              value={profile.bio}
              onChange={(e) => update("bio", e.target.value)}
              placeholder="Short bio"
              rows={3}
              style={{ width: "100%", fontSize: 13, resize: "vertical" }}
            />
          ) : (
            <p style={{ fontSize: 13, lineHeight: 1.6, color: "var(--color-text-secondary)", textAlign: "center", margin: 0 }}>
              {profile.bio}
            </p>
          )}
        </div>

        {/* Social links */}
        <div style={{ padding: "16px 20px 0", display: "flex", flexDirection: "column", gap: 8 }}>
          {profile.links.map((link) => {
            const Icon = PLATFORM_ICONS[link.platform] || Link;
            return (
              <div key={link.id}>
                {editing ? (
                  <div style={{ display: "flex", gap: 6, alignItems: "center" }}>
                    <select
                      value={link.platform}
                      onChange={(e) => updateLink(link.id, "platform", e.target.value)}
                      style={{ fontSize: 12, width: 110 }}
                    >
                      {Object.entries(PLATFORM_LABELS).map(([key, label]) => (
                        <option key={key} value={key}>{label}</option>
                      ))}
                    </select>
                    <input
                      value={link.value}
                      onChange={(e) => updateLink(link.id, "value", e.target.value)}
                      placeholder="username or url"
                      style={{ fontSize: 12, flex: 1 }}
                    />
                    <button
                      onClick={() => removeLink(link.id)}
                      aria-label="Remove link"
                      style={{ width: 32, height: 32, padding: 0, display: "flex", alignItems: "center", justifyContent: "center" }}
                    >
                      <Trash2 size={14} aria-hidden="true" />
                    </button>
                  </div>
                ) : (
                  link.value && (
                    <a
                      href={normalizeLink(link.platform, link.value)}
                      style={{
                        display: "flex",
                        alignItems: "center",
                        gap: 10,
                        padding: "10px 12px",
                        borderRadius: "var(--border-radius-md)",
                        border: "0.5px solid var(--color-border-tertiary)",
                        fontSize: 13,
                        textDecoration: "none",
                        color: "var(--color-text-primary)",
                      }}
                    >
                      <span
                        style={{
                          width: 28,
                          height: 28,
                          borderRadius: "50%",
                          background: accent.soft,
                          color: accent.text,
                          display: "flex",
                          alignItems: "center",
                          justifyContent: "center",
                          flexShrink: 0,
                        }}
                      >
                        <Icon size={15} aria-hidden="true" />
                      </span>
                      <span style={{ flex: 1, overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>
                        {link.value}
                      </span>
                      <ExternalLink size={14} aria-hidden="true" style={{ color: "var(--color-text-tertiary)" }} />
                    </a>
                  )
                )}
              </div>
            );
          })}
          {editing && (
            <button
              onClick={addLink}
              style={{ display: "flex", alignItems: "center", justifyContent: "center", gap: 6, fontSize: 12, padding: "8px" }}
            >
              <Plus size={14} aria-hidden="true" /> Add link
            </button>
          )}
        </div>

        {/* Contact info */}
        <div style={{ padding: "16px 20px 20px", marginTop: 8, borderTop: "0.5px solid var(--color-border-tertiary)" }}>
          {[
            { icon: Mail, field: "email", placeholder: "Email address", href: (v) => `mailto:${v}` },
            { icon: Phone, field: "phone", placeholder: "Phone number", href: (v) => `tel:${v.replace(/\s/g, "")}` },
            { icon: MapPin, field: "location", placeholder: "Location", href: null },
          ].map(({ icon: Icon, field, placeholder, href }) => (
            <div key={field} style={{ display: "flex", alignItems: "center", gap: 10, padding: "6px 0", fontSize: 13 }}>
              <Icon size={16} aria-hidden="true" style={{ color: accent.text, flexShrink: 0 }} />
              {editing ? (
                <input
                  value={profile[field]}
                  onChange={(e) => update(field, e.target.value)}
                  placeholder={placeholder}
                  style={{ fontSize: 13, flex: 1 }}
                />
              ) : profile[field] ? (
                href ? (
                  <a href={href(profile[field])} style={{ color: "var(--color-text-primary)", textDecoration: "none" }}>
                    {profile[field]}
                  </a>
                ) : (
                  <span>{profile[field]}</span>
                )
              ) : null}
            </div>
          ))}
        </div>
      </div>

      {saved && (
        <p style={{ textAlign: "center", fontSize: 12, color: "#fff", marginTop: 10 }}>
          Profile updated
        </p>
      )}
      {!editing && !saved && (
        <p style={{ textAlign: "center", fontSize: 12, color: "rgba(255,255,255,0.65)", marginTop: 10 }}>
          This is the page visitors see after tapping your NFC card
        </p>
      )}
      </div>
    </div>
  );
}
